# ========================
# AI QUIZ SYSTEM - ENVIRONMENT VARIABLES
# ========================
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control

# ========================
# GEMINI API CONFIGURATION
# ========================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyYourActualGeminiAPIKeyHere...

# ========================
# SERVER CONFIGURATION
# ========================
# Server port (default: 3000)
PORT=3000

# Node environment: development or production
NODE_ENV=development

# Server URL for frontend (used in CORS)
SERVER_URL=http://localhost:3000

# ========================
# DATABASE CONFIGURATION (Optional - for future use)
# ========================
# MongoDB connection string (if using MongoDB)
# MONGODB_URI=mongodb://username:password@localhost:27017/quiz-system

# PostgreSQL connection string (if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/quiz_system

# ========================
# FILE UPLOAD CONFIGURATION
# ========================
# Maximum file size for uploads (in bytes)
# 10MB = 10485760
MAX_FILE_SIZE=10485760

# Upload directory
UPLOAD_DIR=uploads

# Allowed image MIME types (comma-separated)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ========================
# QUIZ CONFIGURATION
# ========================
# Default quiz duration in seconds (15 minutes = 900 seconds)
DEFAULT_QUIZ_DURATION=900

# Number of questions for auto-generated quizzes
DEFAULT_NUM_QUESTIONS=5

# ========================
# AI MODEL CONFIGURATION
# ========================
# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# Temperature for AI responses (0.0 to 1.0)
# Lower = more deterministic, Higher = more creative
AI_TEMPERATURE=0.7

# ========================
# LOGGING CONFIGURATION
# ========================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ========================
# CORS CONFIGURATION
# ========================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ========================
# SECURITY CONFIGURATION
# ========================
# JWT Secret (for future authentication)
# JWT_SECRET=your_super_secret_jwt_key_here

# CORS allowed credentials
CORS_CREDENTIALS=true

# ========================
# NOTIFICATION CONFIGURATION (Optional)
# ========================
# Email service for sending results (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@quizsystem.com

# ========================
# ANALYTICS CONFIGURATION (Optional)
# ========================
# Google Analytics ID (optional)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
